# ============================================================
#  WildGuard Chile – Variables de Entorno
#  Archivo raíz del proyecto (.env)
# ============================================================

# --- Datadog ---
DD_API_KEY=46ebaeb6a7e4c59b162d107d3de77502
DD_SITE=us5.datadoghq.com
DD_ENV=wildguard-dev
DD_SERVICE=wildguard
DD_VERSION=1.0.0

# --- PostgreSQL (Data Lake: bronze / silver / gold) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=wildguard
POSTGRES_USER=wildguard
POSTGRES_PASSWORD=wg_secret_2024

# --- Redis Streams (reemplaza Kinesis Data Streams + Firehose) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Sensor Simulator (MQTT simulado) ---
SENSOR_EMIT_INTERVAL_MS=5000
SENSOR_COUNT=12
SENSOR_ZONES=malalcahuello,nahuelbuta,villarrica,cani,radal7tazas

# --- Weather API (Open-Meteo — sin API key, gratuita) ---
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
WEATHER_AIRQUALITY_URL=https://air-quality-api.open-meteo.com/v1/air-quality
WEATHER_FETCH_INTERVAL_MS=60000

# --- ETL Processor ---
ETL_BATCH_INTERVAL_MS=30000
ETL_STREAM_BATCH_SIZE=50

# --- ML Simulator ---
ML_INFERENCE_INTERVAL_MS=20000
ML_MODEL_VERSION=wg-fwi-classifier-v1.2
ML_THRESHOLD=0.50

# --- Alert Service ---
ALERT_WEBHOOK_URL=http://dashboard:8088/api/alerts/ingest
ALERT_WEBHOOK_EXTERNAL=
ALERT_EVAL_INTERVAL_MS=10000

# --- Alert Channels (opcionales) ---
# Telegram
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=dummy
TELEGRAM_CHAT_ID=dummy
# Slack
SLACK_ENABLED=true
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/dummy
# Email (SMTP)
EMAIL_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=dummy
SMTP_PASS=dummy
SMTP_FROM=dummy@example.com
SMTP_TO_ALERTS=dummy@example.com
EMAIL_FROM=dummy@example.com
EMAIL_TO=dummy@example.com

# --- Dashboard ---
DASHBOARD_PORT=8088

# --- Retención Data Lake ---
BRONZE_RETENTION_DAYS=365
SILVER_RETENTION_DAYS=730
GOLD_RETENTION_DAYS=1825

# --- Seguridad ---
GPS_HASH_SALT=wg_gps_salt_chile_2024
API_SECRET_KEY=wg_internal_api_key_2024

# --- MQTT / Mosquitto ---
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_WEBSOCKET_PORT=9001
MQTT_TOPIC_IOT=wildguard/sensors/iot/#
MQTT_TOPIC_GPS=wildguard/sensors/gps/#
MQTT_TOPIC_ALERTS=wildguard/alerts/fire

# --- Datadog APM (ddtrace) ---
DD_TRACE_ENABLED=true
DD_APM_ENABLED=true
DD_TRACE_AGENT_PORT=8126
DD_LOGS_INJECTION=true
DD_RUNTIME_METRICS_ENABLED=true
DD_PROFILING_ENABLED=false
DD_TRACE_SAMPLE_RATE=1.0
DD_TRACE_ANALYTICS_ENABLED=true

# --- Gold Layer ---
GOLD_KPI_WINDOW_S=30
